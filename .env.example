# Public site URL (no trailing slash). Used to fix canonical, og:url, and social image URLs
# on Vercel preview vs production. Falls back to values in index.html if unset.
# VITE_SITE_URL=https://missout.in

# Web3Forms access key — contact form POSTs to api.web3forms.com when set.
# Without it, submit opens the visitor's mail client (mailto fallback).
# VITE_WEB3FORMS_ACCESS_KEY=
